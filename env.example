# LifeQuest Kingston - Environment Variables
# Copy this file to .env.local and fill in your values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LifeQuest Kingston

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
DYNAMODB_TABLE_PREFIX=lifequest_

# Backboard.io
BACKBOARD_API_KEY=your_backboard_key
BACKBOARD_PROJECT_ID=your_project_id

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID_SERGEANT=voice_id_1
ELEVENLABS_VOICE_ID_SAGE=voice_id_2
ELEVENLABS_VOICE_ID_HYPE=voice_id_3

# Auth (simple JWT for MVP)
JWT_SECRET=your-super-secret-jwt-key-change-this
